# ── Nela Zahradnice Portal – Backend env ───────────────────
# Kopíruj jako .env a doplň hodnoty

# Server
NODE_ENV=development
PORT=3000
DATA_DIR=./data
UPLOAD_DIR=./data/projekty

# Google Drive Service Account
# Vytvoř projekt v Google Cloud Console → povol Drive API →
// vytvoř Service Account → vygeneruj JSON klíč →
// nasdílej složku Service Accountu
// Formát: Base64-encoded JSON nebo plain JSON
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
